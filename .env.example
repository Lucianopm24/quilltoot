# Copia este archivo a .env y llena los valores reales.
# NUNCA subas el .env real a GitHub (ya está en .gitignore).

# Connection string de Postgres (Supabase: Project Settings > Database > Connection string)
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Dominio donde vas a hostear esta instancia (sin protocolo, sin barra final)
# Se usa para construir URIs de ActivityPub (Actor, statuses, WebFinger...)
# CAMBIARLO DESPUES DE HABER INICIADO EL SERVIDOR PUEDE GENERAR PROBLEMAS EN LA FEDERACIÓN
INSTANCE_DOMAIN=tudominio.com

# true = cualquiera puede crear cuenta con POST /auth/register
# false = solo un admin autenticado puede crear cuentas nuevas
OPEN_REGISTRATION=false

# Puerto local (Vercel/Railway lo ignoran y usan el suyo propio automáticamente)
PORT=3000

# ¿Cualquiera puede mandar POST /auth/register, o solo un admin ya
# logueado puede crear cuentas nuevas? Desactivado (false) por defecto.
OPEN_REGISTRATION=false

# ¿Las cuentas nuevas quedan 'pending' hasta que un admin las apruebe?
# ACTIVADO por defecto — si no defines esta variable, se comporta como
# si fuera "true". Para desactivarlo hay que poner explícitamente "false".
APPROVAL_REQUIRED=true